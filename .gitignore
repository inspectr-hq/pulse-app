# macOS
.DS_Store

# Xcode user state
xcuserdata/
*.xcuserstate
*.xcscmblueprint

# Build output
build/
DerivedData/

# Swift Package Manager
.build/
.swiftpm/

# Keep SwiftPM lock files tracked
!Package.resolved
!**/Package.resolved

# Xcode SwiftPM resolved dependencies
!*.xcodeproj/project.xcworkspace/xcshareddata/swiftpm/Package.resolved
!*.xcworkspace/xcshareddata/swiftpm/Package.resolved

# SwiftPM generated dependency checkouts, if present
Packages/
Package.pins

# CocoaPods, if used
Pods/
# Usually commit Podfile.lock for apps
# !Podfile.lock

# Carthage, if used
Carthage/Build/

# Fastlane generated output
fastlane/report.xml
fastlane/Preview.html
fastlane/screenshots/**/*.png
fastlane/test_output/

# Secrets / local config
*.env
.env
.env.*
*.xcconfig.local